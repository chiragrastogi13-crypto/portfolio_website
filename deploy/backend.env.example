# Production backend config for the Oracle VM.
# Copy to  backend/.env  on the server and fill real values.
# (This file is only an example — never commit real secrets.)

# --- URL scheme: wildcard subdomains on the real domain ----------------------
BASE_HOST=wlelo.com
BASE_PORT=443
USE_PATH_URLS=false

# --- Security ----------------------------------------------------------------
# Generate once:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_LONG_RANDOM_VALUE
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database ----------------------------------------------------------------
# SQLite file on the VM's persistent disk is enough for a small app and keeps
# it 100% free (no separate DB service). Upgrade to Postgres later if needed.
DATABASE_URL=sqlite:///./blogger.db

# --- Admin account (auto-created on first startup) ---------------------------
ADMIN_EMAIL=admin@wlelo.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- CORS --------------------------------------------------------------------
# Same-origin now (API served under wlelo.com), so this mainly covers www.
FRONTEND_ORIGINS=https://wlelo.com,https://www.wlelo.com

# --- UPI payment details -----------------------------------------------------
UPI_VPA=7071946603@ybl
UPI_NAME=Website Lelo

# --- Email (optional; leave blank to skip sending) ---------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
